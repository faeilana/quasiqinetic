# Copy to .env and fill in values before running
# Sentry — get DSN from your project settings at sentry.io
VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Backend URL (where FastAPI runs)
VITE_BACKEND_URL=http://localhost:8000

# Arize AX — used by FastAPI backend, not the browser
# Get from app.arize.com → Settings → Space & API Keys
ARIZE_API_KEY=...
ARIZE_SPACE_ID=...
